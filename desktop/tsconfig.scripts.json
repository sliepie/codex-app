{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "rootDir": "scripts",
    "outDir": ".cache/scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/decode-self-signed-pfx.ts",
    "scripts/hydrate-codex-app.ts",
    "scripts/hydrate-codex-cli.ts",
    "scripts/patch-windows-self-signed-bundle.ts",
    "scripts/prepare-self-signed-msix-payload.ts",
    "scripts/write-self-signed-appinstaller.ts"
  ]
}
