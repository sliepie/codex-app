{
  "name": "codex-desktop",
  "productName": "Codex",
  "version": "0.0.0",
  "description": "Codex",
  "main": "codex-plusplus/loader.cjs",
  "private": true,
  "author": "OpenAI",
  "engines": {
    "node": "24"
  },
  "codexBuildFlavor": "prod",
  "scripts": {
    "build:scripts": "npx -y -p @typescript/native-preview@beta tsgo -p tsconfig.scripts.json",
    "build:windows-oai-update-checker": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-windows-oai-update-checker.ps1",
    "test:patch-windows-self-signed-bundle": "npm run build:scripts && node --test scripts/patch-windows-self-signed-bundle.test.mjs",
    "test:patch-windows-self-signed-bundle:compiled": "node --test scripts/patch-windows-self-signed-bundle.test.mjs",
    "test:resolve-codex-releases": "npm run build:scripts && node --test scripts/resolve-codex-releases.test.mjs",
    "test:resolve-codex-releases:compiled": "node --test scripts/resolve-codex-releases.test.mjs",
    "test:verify-browser-client-runtime": "npm run build:scripts && node --test scripts/verify-browser-client-runtime.test.mjs",
    "test:verify-browser-client-runtime:compiled": "node --test scripts/verify-browser-client-runtime.test.mjs",
    "test:windows-package-resources": "npm run build:scripts && node --test scripts/windows-package-resources.test.mjs",
    "test:windows-package-resources:compiled": "node --test scripts/windows-package-resources.test.mjs",
    "verify:browser-client-runtime": "npm run build:scripts && npm run verify:browser-client-runtime:compiled",
    "verify:browser-client-runtime:compiled": "node ./.cache/scripts/verify-browser-client-runtime.js",
    "prepare:win:arm64": "npm run build:scripts && npm run download:tectonic:win:x64 && npm run build:windows-oai-update-checker -- -Architecture arm64 && npm run hydrate:app:compiled && npm run hydrate:cli:compiled && npm run verify:browser-client-runtime:compiled",
    "hydrate:app": "npm run build:scripts && node ./.cache/scripts/hydrate-codex-app.js",
    "hydrate:cli": "npm run build:scripts && node ./.cache/scripts/hydrate-codex-cli.js",
    "hydrate:app:compiled": "node ./.cache/scripts/hydrate-codex-app.js",
    "hydrate:cli:compiled": "node ./.cache/scripts/hydrate-codex-cli.js",
    "decode:self-signed-pfx": "npm run build:scripts && node ./.cache/scripts/decode-self-signed-pfx.js",
    "decode:self-signed-pfx:compiled": "node ./.cache/scripts/decode-self-signed-pfx.js",
    "package:win:arm64:compiled": "electron-forge package --platform win32 --arch arm64",
    "package:win:arm64": "npm run prepare:win:arm64 && npm run package:win:arm64:compiled",
    "prepare:self-signed-msix-payload": "npm run build:scripts && node ./.cache/scripts/prepare-self-signed-msix-payload.js",
    "prepare:self-signed-msix-payload:compiled": "node ./.cache/scripts/prepare-self-signed-msix-payload.js",
    "refresh:recovered": "npm run build:scripts && node ./.cache/scripts/refresh-recovered-from-dmg.js",
    "write:self-signed-appinstaller": "npm run build:scripts && node ./.cache/scripts/write-self-signed-appinstaller.js",
    "write:self-signed-appinstaller:compiled": "node ./.cache/scripts/write-self-signed-appinstaller.js",
    "make:win:arm64:compiled": "electron-forge make --platform win32 --arch arm64",
    "make:win:arm64:ci": "npm run prepare:win:arm64 && npm run make:win:arm64:compiled",
    "make:win:arm64": "npm run prepare:win:arm64 && npm run make:win:arm64:compiled",
    "build:primary-runtime:win:arm64": "npm run build:scripts && npm run build:primary-runtime:win:arm64:compiled",
    "build:primary-runtime:win:arm64:compiled": "node ./.cache/scripts/build-primary-runtime-win-arm64.js",
    "resolve:primary-runtime-source": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/resolve-primary-runtime-source.ts",
    "publish:primary-runtime:win:arm64:compiled": "node ./.cache/scripts/publish-primary-runtime-release.js",
    "update:node-repl": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-node-repl.ps1",
    "download:tectonic:win:x64": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/download-tectonic-windows-x64.ps1"
  },
  "keywords": [
    "electron",
    "vite",
    "typescript",
    "desktop"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/asar": "^3.4.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "electron": "42.0.1",
    "extract-zip": "^2.0.1",
    "node-abi": "^4.31.0"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
