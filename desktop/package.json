  "private": true,
  "author": "OpenAI",
  "engines": {
    "node": "22.x"
  },
  "codexBuildFlavor": "prod",
  "scripts": {
    "build:scripts": "npx -y -p @typescript/native-preview@beta tsgo -p tsconfig.scripts.json",
    "hydrate:app": "npm run build:scripts && node ./.cache/scripts/hydrate-codex-app.js",
    "hydrate:cli": "npm run build:scripts && node ./.cache/scripts/hydrate-codex-cli.js",
    "package:win:arm64": "npm run hydrate:app && npm run hydrate:cli && electron-forge package --platform win32 --arch arm64",
    "refresh:recovered": "node ./scripts/refresh-recovered-from-dmg.mjs",
    "make:win:arm64:ci": "npm run hydrate:app && npm run hydrate:cli && electron-forge make --platform win32 --arch arm64",
    "make:win:arm64": "npm run hydrate:app && npm run hydrate:cli && electron-forge make --platform win32 --arch arm64"
